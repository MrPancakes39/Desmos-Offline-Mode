    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "fetch_desmos_resources": "file:./fetch_desmos_res",
    "less": "^4.2.0",
